{
  "name": "specminer",
  "version": "0.1.0",
  "description": "Evidence-based requirements mining for existing web applications.",
  "type": "module",
  "bin": {
    "specminer": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "requirements",
    "playwright",
    "legacy",
    "user-stories",
    "gherkin"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "playwright": "^1.49.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
