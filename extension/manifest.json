{
  "manifest_version": 3,
  "name": "SpecMiner Recorder",
  "version": "0.1.0",
  "description": "Passive browser-side recorder for SpecMiner hybrid capture workflows.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "SpecMiner Recorder"
  }
}
